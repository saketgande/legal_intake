# Copy to .env.local and edit. .env.local is gitignored.
#
# Local dev (after `docker compose up -d`):
DATABASE_URL="postgresql://aegis:aegis@localhost:5432/aegis?schema=public"

# Server-only — never expose to the client. /api/claude proxies through this.
ANTHROPIC_API_KEY=

# Intake agents: surface the demo-only mock agents (Trademark Clearance,
# Contract Review) that lack real backends. UNSET / false in production so
# customers never see fabricated analysis — those ticket types fall through
# to honest manual triage. Set to "true" on a SALES DEMO deployment to show
# all six agents. NEXT_PUBLIC_ so it reaches the client bundle at build time.
NEXT_PUBLIC_AEGIS_DEMO_AGENTS=false
