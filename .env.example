# Copy to .env.local and edit. .env.local is gitignored.
#
# Local dev (after `docker compose up -d`):
DATABASE_URL="postgresql://aegis:aegis@localhost:5432/aegis?schema=public"

# Server-only — never expose to the client. /api/claude proxies through this.
ANTHROPIC_API_KEY=

# At-rest encryption key for stored secrets (M365 client secret + delegated
# refresh token). 32 bytes, base64 or hex — generate with:
#   openssl rand -base64 32
# When set, secrets are sealed with AES-256-GCM (v2). When unset, dev
# stores plaintext (v1); in production a missing key FAILS LOUD rather
# than storing plaintext. Required for any client using M365 email.
AEGIS_ENCRYPTION_KEY=

# Intake agents production gate. All six agents are now real (Claude-backed)
# and productionReady, so this flag currently hides nothing. It remains the
# seam for any FUTURE not-yet-real agent: mark it productionReady:false and
# it stays hidden unless this is "true". NEXT_PUBLIC_ so it reaches the
# client bundle at build time.
NEXT_PUBLIC_AEGIS_DEMO_AGENTS=false

# Intake email channel. The inbound webhook at
# POST /api/intake/email-webhook turns an email into an IntakeTicket
# (classify + route + audit). The request must carry this secret in the
# `x-aegis-webhook-secret` header (or `?secret=`), compared in constant
# time. FAIL-CLOSED in production: if NODE_ENV=production and this is
# unset, the endpoint returns 503 (never an open ingest endpoint). In
# dev (unset) it stays open so it's curl-demoable.
AEGIS_EMAIL_WEBHOOK_SECRET=

# Deployment profile. "full" (default) shows every module in the side-nav.
# "intake" ships an Intake-only navigation — the client sees only Legal
# Intake plus the admin tools Intake needs (Users / Roles / Audit Log,
# still permission-gated). The rest of the platform (agents, M365 email
# polling, ticket→matter auto-spawn, the audit chain) keeps running
# underneath, so Intake runs at full capability. NEXT_PUBLIC_ so it
# reaches the client bundle at build time.
NEXT_PUBLIC_AEGIS_PROFILE=full
