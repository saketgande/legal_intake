{
  "name": "@aegis/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "files": ["src", "prisma"],
  "scripts": {
    "build": "prisma generate",
    "postinstall": "prisma generate || echo '[@aegis/db] prisma generate skipped (likely a CI fallback without @prisma/client present)'",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "echo '[@aegis/db] skipping unit tests in default test stage — they need DATABASE_URL. Use `pnpm --filter @aegis/db run test:db` (CI db-integrity job runs them).' && exit 0",
    "test:db": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:audit-canary": "tsx scripts/audit-canary.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "pdfkit": "0.15.2"
  },
  "devDependencies": {
    "@aegis/eslint-config": "workspace:*",
    "@types/node": "^20.17.9",
    "@types/pdfkit": "0.13.9",
    "eslint": "^8.57.1",
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "typescript": "5.6.3",
    "vitest": "1.6.1"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
